# Copy to .env for local dev, or put these in /etc/conf.d/homer-metrics on the server
# OpenRC sources /etc/conf.d/homer-metrics automatically — use `export` so the daemon inherits them

# Proxmox API token (Datacenter → Permissions → API Tokens)
HOMER_PVE_TOKEN=PVEAPIToken=user@pve!token-name=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Proxmox API base URL (required)
HOMER_PVE_API=https://192.168.x.x:8006/api2/json

# Optional overrides
# HOMER_PVE_NODE=pve
# HOMER_SERVICES=/opt/homer-services.json
